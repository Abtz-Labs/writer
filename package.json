{
  "name": "serif-blog",
  "version": "1.0.1",
  "description": "A simple, single-tenant blog web application with RESTful API",
  "type": "module",
  "main": "app.js",
  "scripts": {
    "start": "nodemon app.js -p 8080",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "deploy": "bare deploy"
  },
  "keywords": [
    "blog",
    "express",
    "ejs",
    "jslitedb",
    "serif"
  ],
  "author": "",
  "license": "MIT",
