<div class="panel-layout">
    <nav class="panel-nav">
        <div class="panel-nav-inner">
            <a class="panel-logo" href="/panel">Panel</a>
            <div class="panel-nav-links">
                <a href="/panel">Posts</a>
                <a href="/settings" class="is-active">Settings</a>
                <form method="POST" action="/logout" style="display: inline">
                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                    <button type="submit" class="button-link">Logout</button>
                </form>
            </div>
        </div>
    </nav>
    <div class="panel-content">
        <div class="notification-container"></div>
        <div class="panel-header">
            <h1 class="panel-title">Settings</h1>
            <div class="panel-actions"></div>
        </div>

        <section class="form-section">
            <div class="settings-grid">
                <div class="box is-fullheight">
                    <h3 class="title is-5">General</h3>
                    <form
                        id="settingsForm"
                        method="POST"
                        action="/settings/update"
                    >
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div>
                            <div class="field">
                                <label class="label" for="title"
                                    >Blog Title</label
                                >
                                <input
                                    type="text"
                                    id="title"
                                    name="title"
                                    required
                                    value="<%= settings.title || '' %>"
                                />
                            </div>
                            <div class="field">
                                <label class="label" for="author"
                                    >Author Name</label
                                >
                                <input
                                    type="text"
                                    id="author"
                                    name="author"
                                    value="<%= settings.author || '' %>"
                                />
                            </div>
                            <div class="field">
                                <label class="label" for="description"
                                    >Blog Description</label
                                >
                                <textarea id="description" name="description">
<%= settings.description || '' %></textarea
                                >
                            </div>
                            <div class="field">
                                <label class="checkbox-label">
                                    <input type="checkbox" id="showDocs" name="show_docs" <%= settings.show_docs !== false ? 'checked' : '' %>>
                                    Show API Docs link in footer
                                </label>
                            </div>
                        </div>
                        <button
                            type="submit"
                            class="button is-primary is-fullwidth"
                        >
                            Save
                        </button>
                    </form>
                </div>

                <div class="box is-fullheight">
                    <h3 class="title is-5">Credentials</h3>
                    <form
                        id="credentialsForm"
                        method="POST"
                        action="/settings/update-credentials"
                    >
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <div>
                            <div class="field">
                                <label class="label" for="username"
                                    >Username</label
                                >
                                <input
                                    type="text"
                                    id="username"
                                    name="username"
                                    value="<%= settings.username || '' %>"
                                    placeholder="Enter username"
                                />
                            </div>
                            <div class="field">
                                <label class="label" for="password"
                                    >New Password</label
                                >
                                <input
                                    type="password"
                                    id="password"
                                    name="password"
                                    placeholder="Enter new password"
                                />
                                <% if (settings.hasPassword) { %>
                                <p class="help">
                                    Leave blank to keep current password
                                </p>
                                <% } %>
                            </div>
                            <div class="field">
                                <label class="label" for="confirmPassword"
                                    >Confirm Password</label
                                >
                                <input
                                    type="password"
                                    id="confirmPassword"
                                    name="confirmPassword"
                                    placeholder="Confirm new password"
                                />
                            </div>
                        </div>
                        <button
                            type="submit"
                            class="button is-primary is-fullwidth"
                        >
                            Save
                        </button>
                    </form>
                </div>

                <div class="box is-fullwidth">
                    <h3 class="title is-5">About the Author</h3>
                    <form id="aboutForm">
                        <div class="field">
                            <textarea
                                id="about"
                                name="about"
                                rows="4"
                                maxlength="280"
                                placeholder="A brief description about yourself..."
                            ><%= settings.about || '' %></textarea>
                            <p class="help">
                                Write a brief description about yourself. Max 280 characters.
                            </p>
                        </div>
                        <button
                            type="submit"
                            class="button is-primary is-fullwidth"
                        >
                            Save
                        </button>
                    </form>
                </div>

                <div class="box is-fullwidth">
                    <h3 class="title is-5">Custom Scripts</h3>
                    <form id="customScriptsForm">
                        <div class="field">
                            <textarea
                                id="customScripts"
                                name="custom_scripts"
                                rows="6"
                                placeholder="<script>...</script>"
                            ><%= settings.custom_scripts || '' %></textarea>
                            <p class="help">
                                Add custom script tags (e.g., analytics) to be
                                included in every page.
                            </p>
                        </div>
                        <div class="field">
                            <label class="label" for="cspScriptDomains">Allowed Script Domains</label>
                            <textarea
                                id="cspScriptDomains"
                                name="csp_script_domains"
                                rows="3"
                                placeholder="https://www.googletagmanager.com, https://www.google-analytics.com"
                            ><%= settings.csp_script_domains || '' %></textarea>
                            <p class="help">
                                Comma-separated list of external domains allowed to load scripts
                                (added to the Content Security Policy).
                            </p>
                        </div>
                        <button
                            type="submit"
                            class="button is-primary is-fullwidth"
                        >
                            Save
                        </button>
                    </form>
                </div>

                <div class="box is-fullwidth">
                    <h3 class="title is-5">Security</h3>
                    <form
                        id="rotateTokenForm"
                        method="POST"
                        action="/settings/rotate-token"
                    >
                        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                        <p class="mb-3">
                            Rotate your auth token if you suspect it has been
                            compromised. <br />
                            <strong
                                >Make sure to update any applications using the
                                old token.</strong
                            >
                        </p>
                        <button
                            type="submit"
                            class="button is-outline is-danger"
                        >
                            Rotate Auth Token
                        </button>
                    </form>
                </div>
            </div>

            <div class="result-box" id="result" style="display: none">
                <h3>Token Rotated!</h3>
                <p>Your new auth token:</p>
                <pre><code id="newTokenDisplay"></code></pre>
                <p class="token-warning">
                    Save this new token! You won't be able to see it again.
                </p>
                <a href="/settings" class="button is-link is-outlined mt-3"
                    >Back to Settings</a
                >
            </div>

            <script>
                document
                    .getElementById("settingsForm")
                    .addEventListener("submit", async (e) => {
                        e.preventDefault();
                        const formData = {
                            title: document.getElementById("title").value,
                            author: document.getElementById("author").value,
                            description:
                                document.getElementById("description").value,
                            show_docs: document.getElementById("showDocs").checked,
                        };
                        try {
                            const res = await fetch("/api/settings", {
                                method: "PUT",
                                headers: {
                                    "Content-Type": "application/json",
                                    "X-Auth-Token": <%- JSON.stringify(token) %>,
                                },
                                body: JSON.stringify(formData),
                            });
                            const data = await res.json();
                            if (data.title) {
                                showNotification("Settings saved successfully!");
                            } else if (data.error) {
                                showNotification(data.message, "danger");
                            }
                        } catch (err) {
                            showNotification("Failed to save settings", "danger");
                        }
                    });

                document
                    .getElementById("rotateTokenForm")
                    .addEventListener("submit", (e) => {
                        e.preventDefault();
                        showConfirmModal({
                            title: "Rotate Auth Token",
                            message: "Are you sure you want to rotate your auth token? Any applications using the current token will lose access.",
                            confirmText: "Rotate",
                            confirmClass: "is-danger",
                            onConfirm: async () => {
                                try {
                                    const res = await fetch(
                                        "/api/settings/rotate-token",
                                        {
                                            method: "POST",
                                            headers: { "X-Auth-Token": <%- JSON.stringify(token) %> },
                                        },
                                    );
                                    const data = await res.json();
                                    if (data.confirmation_required && data.confirmation_url) {
                                        const confirmRes = await fetch(data.confirmation_url, {
                                            method: "POST",
                                            headers: { "X-Auth-Token": <%- JSON.stringify(token) %> },
                                        });
                                        const confirmData = await confirmRes.json();
                                        if (confirmData.auth_token) {
                                            document.querySelector(
                                                ".settings-grid",
                                            ).style.display = "none";
                                            document.getElementById(
                                                "result",
                                            ).style.display = "block";
                                            document.getElementById(
                                                "newTokenDisplay",
                                            ).textContent = confirmData.auth_token;
                                            showNotification("Auth token rotated successfully!");
                                        } else if (confirmData.error) {
                                            showNotification(confirmData.message, "danger");
                                        }
                                    } else if (data.auth_token) {
                                        document.querySelector(
                                            ".settings-grid",
                                        ).style.display = "none";
                                        document.getElementById(
                                            "result",
                                        ).style.display = "block";
                                        document.getElementById(
                                            "newTokenDisplay",
                                        ).textContent = data.auth_token;
                                        showNotification("Auth token rotated successfully!");
                                    } else if (data.error) {
                                        showNotification(data.message, "danger");
                                    }
                                } catch (err) {
                                    showNotification("Failed to rotate token", "danger");
                                }
                            },
                        });
                    });

                document
                    .getElementById("credentialsForm")
                    .addEventListener("submit", async (e) => {
                        e.preventDefault();
                        const password =
                            document.getElementById("password").value;
                        const confirmPassword =
                            document.getElementById("confirmPassword").value;
                        if (password && password !== confirmPassword) {
                            showNotification("Passwords do not match", "warning");
                            return;
                        }
                        const formData = {
                            username: document.getElementById("username").value,
                            password: password,
                        };
                        try {
                            const res = await fetch(
                                "/api/settings/credentials",
                                {
                                    method: "PUT",
                                    headers: {
                                        "Content-Type": "application/json",
                                        "X-Auth-Token": <%- JSON.stringify(token) %>,
                                    },
                                    body: JSON.stringify(formData),
                                },
                            );
                            const data = await res.json();
                            if (data.username) {
                                showNotification("Credentials saved successfully!");
                                document.getElementById("password").value = "";
                                document.getElementById(
                                    "confirmPassword",
                                ).value = "";
                            } else if (data.error) {
                                showNotification(data.message, "danger");
                            }
                        } catch (err) {
                            showNotification("Failed to save credentials", "danger");
                        }
                    });

                document
                    .getElementById("customScriptsForm")
                    .addEventListener("submit", async (e) => {
                        e.preventDefault();
                        const formData = {
                            custom_scripts:
                                document.getElementById("customScripts").value,
                            csp_script_domains:
                                document.getElementById("cspScriptDomains").value,
                        };
                        try {
                            const res = await fetch("/api/settings", {
                                method: "PUT",
                                headers: {
                                    "Content-Type": "application/json",
                                    "X-Auth-Token": <%- JSON.stringify(token) %>,
                                },
                                body: JSON.stringify(formData),
                            });
                            const data = await res.json();
                            if (data.title !== undefined) {
                                showNotification("Custom scripts saved successfully!");
                            } else if (data.error) {
                                showNotification(data.message, "danger");
                            }
                        } catch (err) {
                            showNotification("Failed to save custom scripts", "danger");
                        }
                    });

                document
                    .getElementById("aboutForm")
                    .addEventListener("submit", async (e) => {
                        e.preventDefault();
                        const formData = {
                            about: document.getElementById("about").value,
                        };
                        try {
                            const res = await fetch("/api/settings", {
                                method: "PUT",
                                headers: {
                                    "Content-Type": "application/json",
                                    "X-Auth-Token": <%- JSON.stringify(token) %>,
                                },
                                body: JSON.stringify(formData),
                            });
                            const data = await res.json();
                            if (data.title !== undefined) {
                                showNotification("About the author saved successfully!");
                            } else if (data.error) {
                                showNotification(data.message, "danger");
                            }
                        } catch (err) {
                            showNotification("Failed to save about the author", "danger");
                        }
                    });
            </script>
        </section>
    </div>
</div>
