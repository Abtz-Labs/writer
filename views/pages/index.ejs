<div class="container">
    <div class="posts-section">
        <div class="posts-grid">
            <% if (posts.length === 0) { %>
            <div class="empty-state">
                <h2>Welcome to your blog!</h2>
                <p>No posts yet. Create your first post using the API:</p>
                <pre><code>curl -X POST /api/posts \
  -H "Content-Type: application/json" \
  -H "X-Auth-Token: YOUR_TOKEN" \
  -d '{"title": "Hello World", "body": "My first post content"}'</code></pre>
                <% if (!settings.onboarding_complete) { %>
                <p class="hint">
                    Visit <a href="/onboarding">/onboarding</a> to set up your
                    blog.
                </p>
                <% } %>
            </div>
            <% } else { %> <% posts.forEach(function(post) { %>
            <article
                class="post-card"
                data-tags="<%= post.tags ? post.tags.join(',') : '' %>"
            >
                <% if (post.firstImage) { %>
                <a href="/post/<%= post.slug %>" class="post-card-image">
                    <img
                        src="<%= post.firstImage %>"
                        alt="<%= post.title %>"
                        loading="lazy"
                    />
                </a>
                <% } %>
                <a href="/post/<%= post.slug %>" class="post-title"
                    ><%= post.title %></a
                >
                <p class="post-excerpt"><%= post.excerpt %></p>
                <div class="post-meta">
                    <span class="post-date"
                        ><%= new
                        Date(post.created_at).toLocaleDateString('en-US', {
                        year: 'numeric', month: 'short', day: 'numeric' })
                        %></span
                    >
                    <span class="separator">·</span>
                    <span class="reading-time"
                        ><%= post.reading_time %> min read</span
                    >
                </div>
            </article>
            <% }); %> <% if (totalPages > 1) { %>
            <nav class="pagination">
                <% if (prevPage) { %>
                <a
                    href="?page=<%= prevPage %><%= activeTag ? '&tag=' + activeTag : '' %>"
                    class="pagination-link"
                    >&larr; prev</a
                >
                <% } %>
                <span class="pagination-info"
                    ><%= currentPage %> / <%= totalPages %></span
                >
                <% if (nextPage) { %>
                <a
                    href="?page=<%= nextPage %><%= activeTag ? '&tag=' + activeTag : '' %>"
                    class="pagination-link"
                    >next &rarr;</a
                >
                <% } %>
            </nav>
            <% } %> <% } %>
        </div>

        <div class="sidebar-column">
            <div class="sidebar">
                <div class="search-box">
                    <h3 class="sidebar-title">Search</h3>
                    <form action="/search" method="GET" class="search-form">
                        <input
                            type="text"
                            name="q"
                            value="<%= typeof query !== 'undefined' ? query : '' %>"
                            placeholder="Search posts..."
                            class="search-input"
                            autocomplete="off"
                        />
                        <button
                            type="submit"
                            class="search-button"
                            aria-label="Search"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                width="16"
                                height="16"
                                viewBox="0 0 24 24"
                                fill="none"
                                stroke="currentColor"
                                stroke-width="2"
                                stroke-linecap="round"
                                stroke-linejoin="round"
                            >
                                <circle cx="11" cy="11" r="8"></circle>
                                <line
                                    x1="21"
                                    y1="21"
                                    x2="16.65"
                                    y2="16.65"
                                ></line>
                            </svg>
                        </button>
                    </form>
                </div>

                <div class="topics-box">
                    <h3 class="sidebar-title">Topics</h3>
                    <div class="tag-list">
                        <a
                            href="/"
                            class="tag<%= !activeTag ? ' is-active' : '' %>"
                            data-filter=""
                            >All</a
                        >
                        <% tags.forEach(function(tag) { %>
                        <a
                            href="/?tag=<%= encodeURIComponent(tag) %>"
                            class="tag<%= activeTag === tag ? ' is-active' : '' %>"
                            data-filter="<%= tag %>"
                            ><%= tag.charAt(0).toUpperCase() + tag.slice(1)
                            %></a
                        >
                        <% }); %>
                    </div>
                </div>

                <% if (settings && settings.about) { %>
                <div class="about-box">
                    <h3 class="sidebar-title">About the Author</h3>
                    <p class="about-box-text"><%= settings.about %></p>
                </div>
                <% } %>
            </div>
        </div>

        <% if (settings && settings.about) { %>
        <div class="about-box-mobile">
            <h3 class="sidebar-title">About the Author</h3>
            <p class="about-box-text"><%= settings.about %></p>
        </div>
        <% } %>
    </div>
</div>

<script>
    (function () {
        var params = new URLSearchParams(window.location.search);
        var activeTag = params.get("tag") || "";

        document.querySelectorAll(".tag-list .tag").forEach(function (tagEl) {
            tagEl.addEventListener("click", function (e) {
                if (this.dataset.filter !== activeTag) {
                    window.location.href = this.href;
                }
                e.preventDefault();
            });
        });

        document.querySelectorAll(".post-card").forEach(function (card) {
            var cardTags = card.dataset.tags
                ? card.dataset.tags.split(",")
                : [];
            if (!activeTag || cardTags.includes(activeTag)) {
                card.style.display = "";
            } else {
                card.style.display = "none";
            }
        });
    })();
</script>
