<% if (!isAuthenticated) { %>
<section class="form-section">
  <div class="has-text-centered mb-5">
    <h1 class="title">Admin Panel</h1>
    <% if (settings.username && settings.hasPassword) { %>
    <p class="subtitle">Enter your username and password, or auth token.</p>
    <% } else { %>
    <p class="subtitle">Enter your auth token to access the admin panel.</p>
    <% } %>
  </div>

  <% if (error) { %>
  <div class="notification is-danger is-light mb-4"><%= error %></div>
  <% } %>

  <div class="box">
    <form id="loginForm" method="POST" action="/panel/login">
      <% if (settings.username && settings.hasPassword) { %>
      <div class="field">
        <label class="label" for="username">Username</label>
        <input type="text" id="username" name="username" placeholder="Enter username">
      </div>
      <div class="field">
        <label class="label" for="password">Password</label>
        <input type="password" id="password" name="password" placeholder="Enter password">
      </div>
      <div class="field">
        <label class="label">Or use auth token</label>
      </div>
      <% } %>
      <div class="field">
        <label class="label" for="token">Auth Token</label>
        <input type="password" id="token" name="token" <%= (settings.username && settings.hasPassword) ? '' : 'required' %> placeholder="Enter your auth token">
      </div>
      <button type="submit" class="button is-primary is-fullwidth">Login</button>
    </form>
  </div>
</section>
<% } else { %>
<div class="panel-layout">
  <nav class="panel-nav">
    <div class="panel-nav-inner">
      <a class="panel-logo" href="/panel">Panel</a>
      <div class="panel-nav-links">
        <a href="/panel" class="is-active">Posts</a>
        <a href="/settings">Settings</a>
        <form method="POST" action="/panel/logout" style="display: inline;">
          <button type="submit" class="button-link">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <div class="panel-content">
    <div class="panel-header">
      <h1 class="panel-title">Posts</h1>
      <div class="panel-actions">
        <button class="button is-primary is-small" onclick="showCreateForm()">New Post</button>
      </div>
    </div>

    <div class="post-list">
      <% if (posts.length === 0) { %>
        <div class="empty-list">
          <p>No posts yet. Create your first post to get started.</p>
        </div>
      <% } else { %>
        <table class="posts-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Status</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% posts.forEach(function(post) { %>
              <tr>
                <td class="post-title-cell">
                  <a href="/post/<%= post.slug %>" target="_blank"><%= post.title %></a>
                </td>
                <td>
                  <span class="post-status is-<%= post.status %>"><%= post.status %></span>
                </td>
                <td class="post-date-cell">
                  <%= new Date(post.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                </td>
                <td class="actions-cell">
                  <a href="/post/<%= post.slug %>" target="_blank" class="btn-view">View</a>
                  <button class="btn-edit" onclick="editPost('<%= post.slug %>')">Edit</button>
                  <button class="btn-delete" onclick="deletePost('<%= post.slug %>')">Delete</button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>

    <div id="editForm" class="edit-form" style="display: none">
      <div class="form-header">
        <h3 id="formTitle">Edit Post</h3>
        <button class="btn-close" onclick="cancelEdit()">&times;</button>
      </div>
      <form id="postForm">
        <input type="hidden" id="postSlug" name="slug" value="">
        <div class="field">
          <label class="label" for="title">Title</label>
          <input type="text" id="title" name="title" required value="">
        </div>
        <div class="field">
          <label class="label" for="body">Content</label>
          <textarea id="body" name="body"></textarea>
        </div>
        <div class="field">
          <label class="label" for="status">Status</label>
          <select id="status" name="status">
            <option value="draft">Draft</option>
            <option value="published">Published</option>
          </select>
        </div>
        <div class="form-actions">
          <button type="button" class="button is-outline" onclick="cancelEdit()">Cancel</button>
          <button type="submit" class="button is-primary">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>

<script>
const authToken = '<%= token %>';

function showCreateForm() {
  document.querySelector('.post-list').style.display = 'none';
  document.getElementById('editForm').style.display = 'block';
  document.getElementById('formTitle').textContent = 'New Post';
  document.getElementById('postForm').action = '/api/posts';
  document.getElementById('postSlug').value = '';
  document.getElementById('title').value = '';
  document.getElementById('body').value = '';
  document.getElementById('status').value = 'draft';
}

function editPost(slug) {
  fetch('/api/posts/' + slug, {
    credentials: 'same-origin',
    headers: { 'X-Auth-Token': authToken }
  })
  .then(res => res.json())
  .then(post => {
    document.querySelector('.post-list').style.display = 'none';
  document.getElementById('editForm').style.display = 'block';
  document.getElementById('formTitle').textContent = 'Edit Post';
document.getElementById('postForm').action = '/api/posts/' + slug;
    document.getElementById('postSlug').value = slug;
    document.getElementById('title').value = post.title;
    document.getElementById('body').value = post.body || '';
    document.getElementById('status').value = post.status || 'draft';
  })
  .catch(err => {
    alert('Failed to load post');
  });
}

function cancelEdit() {
  document.querySelector('.post-list').style.display = 'block';
  document.getElementById('editForm').style.display = 'none';
}

function deletePost(slug) {
  if (!confirm('Are you sure you want to delete this post?')) return;

  fetch('/api/posts/' + slug, {
    method: 'DELETE',
    headers: { 'X-Auth-Token': authToken }
  })
  .then(res => res.json())
  .then(data => {
    if (data.message) {
      window.location.reload();
    } else if (data.error) {
      alert(data.message);
    }
  })
  .catch(err => {
    alert('Failed to delete post');
  });
}

document.getElementById('postForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const slug = document.getElementById('postSlug').value;
  const formData = {
    title: document.getElementById('title').value,
    body: document.getElementById('body').value,
    status: document.getElementById('status').value
  };

  const method = slug ? 'PUT' : 'POST';
  const url = slug ? '/api/posts/' + slug : '/api/posts';

  try {
    const res = await fetch(url, {
      method: method,
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json',
        'X-Auth-Token': authToken
      },
      body: JSON.stringify(formData)
    });
    const data = await res.json();
    if (data.slug || data.id) {
      window.location.reload();
    } else if (data.error) {
      alert(data.message);
    }
  } catch (err) {
    alert('Failed to save post');
  }
});
</script>