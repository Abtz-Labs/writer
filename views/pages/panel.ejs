<% if (isAuthenticated) { %>
<div class="panel-layout">
  <nav class="panel-nav">
    <div class="panel-nav-inner">
      <a class="panel-logo" href="/panel">Panel</a>
      <div class="panel-nav-links">
        <a href="/panel" class="is-active">Posts</a>
        <a href="/settings">Settings</a>
        <span> | </span>
        <form method="POST" action="/logout" style="display: inline;">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <button type="submit" class="button-link">Logout</button>
        </form>
      </div>
    </div>
  </nav>

  <div class="panel-content">
    <div class="notification-container"></div>
    <div class="panel-header">
      <h1 class="panel-title">Posts</h1>
      <div class="panel-actions">
        <button class="button is-primary is-small" data-action="create-post">New Post</button>
      </div>
    </div>

    <form class="panel-search-form" action="/panel" method="GET">
      <input
        type="text"
        name="q"
        class="panel-search-input"
        placeholder="Search posts..."
        value="<%= query %>"
        autocomplete="off"
      >
      <button type="submit" class="panel-search-button">Search</button>
      <% if (query) { %>
        <a href="/panel" class="panel-search-clear">Clear</a>
      <% } %>
    </form>

    <div class="post-list">
      <% if (posts.length === 0) { %>
        <div class="empty-list">
          <% if (query) { %>
            <p>No posts match your search.</p>
          <% } else { %>
            <p>No posts yet. Create your first post to get started.</p>
          <% } %>
        </div>
      <% } else { %>
        <table class="posts-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Status</th>
              <th>Created</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% posts.forEach(function(post) { %>
              <tr>
                <td class="post-title-cell">
                  <a href="#" data-action="edit-post" data-slug="<%= post.slug %>"><%= post.title %></a>
                </td>
                <td>
                  <span class="post-status is-<%= post.status %>"><%= post.status %></span>
                </td>
                <td class="post-date-cell">
                  <%= new Date(post.created_at).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }) %>
                </td>
                <td class="actions-cell">
                  <a href="/post/<%= post.slug %>" class="btn-view"><%= post.status === 'draft' ? 'Preview' : 'View' %></a>
                  <button class="btn-edit" data-action="edit-post" data-slug="<%= post.slug %>">Edit</button>
                  <button class="btn-delete" data-action="delete-post" data-slug="<%= post.slug %>">Delete</button>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
<% } %>
      </div>

    <% if (totalPages > 1) { %>
      <nav id="pagination" class="pagination">
        <% if (prevPage) { %>
          <a href="?page=<%= prevPage %><%= query ? '&q=' + encodeURIComponent(query) : '' %>" class="pagination-link">&larr; prev</a>
        <% } %>
        <span class="pagination-info"><%= currentPage %> / <%= totalPages %></span>
        <% if (nextPage) { %>
          <a href="?page=<%= nextPage %><%= query ? '&q=' + encodeURIComponent(query) : '' %>" class="pagination-link">next &rarr;</a>
        <% } %>
      </nav>
    <% } %>

    <div id="editForm" class="edit-form" style="display: none">
      <div class="form-header">
        <h3 id="formTitle">Edit Post</h3>
        <button class="btn-close" data-action="cancel-edit">&times;</button>
      </div>
      <form id="postForm">
        <input type="hidden" id="postSlug" name="slug" value="">
        <div class="field">
          <label class="label" for="title">Title</label>
          <input type="text" id="title" name="title" required value="">
        </div>
        <div class="field">
          <label class="label" for="cover_image">Cover Image URL</label>
          <input type="url" id="cover_image" name="cover_image" placeholder="https://example.com/image.jpg" value="">
          <p class="help">Optional. Provide an external image URL or leave blank to auto-detect from body.</p>
        </div>
        <div class="field">
          <label class="label" for="body">Content</label>
          <div class="markdown-editor">
            <div class="markdown-toolbar">
              <button type="button" data-md-before="**" data-md-after="**" title="Bold"><b>B</b></button>
              <button type="button" data-md-before="*" data-md-after="*" title="Italic"><i>I</i></button>
              <button type="button" data-md-before="# " data-md-after="" title="Heading">H</button>
              <button type="button" data-md-before="[" data-md-after="](url)" title="Link">Link</button>
              <button type="button" data-action="insert-image" title="Image">Img</button>
              <button type="button" data-md-before="`" data-md-after="`" title="Code">Code</button>
              <button type="button" data-md-before="```\n" data-md-after="\n```" title="Code Block">```</button>
              <button type="button" data-md-before="- " data-md-after="" title="List">List</button>
              <button type="button" data-action="insert-table" title="Table">Table</button>
              <button type="button" data-md-before="> " data-md-after="" title="Quote">Quote</button>
            </div>
            <textarea id="body" name="body"></textarea>
          </div>
        </div>
        <div class="field">
          <label class="label" for="status">Status</label>
          <select id="status" name="status">
            <option value="draft">Draft</option>
            <option value="published">Published</option>
          </select>
        </div>
        <div class="form-actions">
          <button type="button" class="button is-outline" data-action="cancel-edit">Cancel</button>
          <button type="submit" class="button is-primary">Save</button>
        </div>
      </form>
    </div>
  </div>
</div>
<% } %>

<script>
const authToken = <%- JSON.stringify(token) %>;

function showCreateForm() {
  document.querySelector('.post-list').style.display = 'none';
  const pagination = document.getElementById('pagination');
  if (pagination) pagination.style.display = 'none';
  document.getElementById('editForm').style.display = 'block';
  document.getElementById('formTitle').textContent = 'New Post';
  document.getElementById('postForm').action = '/api/posts';
  document.getElementById('postSlug').value = '';
  document.getElementById('title').value = '';
  document.getElementById('cover_image').value = '';
  document.getElementById('body').value = '';
  document.getElementById('status').value = 'draft';
}

function editPost(slug) {
  fetch('/api/posts/' + slug, {
    credentials: 'same-origin',
    headers: { 'X-Auth-Token': authToken }
  })
  .then(res => res.json())
  .then(post => {
    document.querySelector('.post-list').style.display = 'none';
    const pagination = document.getElementById('pagination');
    if (pagination) pagination.style.display = 'none';
    document.getElementById('editForm').style.display = 'block';
    document.getElementById('formTitle').textContent = 'Edit Post';
    document.getElementById('postForm').action = '/api/posts/' + slug;
    document.getElementById('postSlug').value = slug;
    document.getElementById('title').value = post.title;
    document.getElementById('cover_image').value = post.cover_image || '';
    document.getElementById('body').value = post.body || '';
    document.getElementById('status').value = post.status || 'draft';
  })
  .catch(err => {
    showNotification('Failed to load post', 'danger');
  });
}

function cancelEdit() {
  document.querySelector('.post-list').style.display = 'block';
  const pagination = document.getElementById('pagination');
  if (pagination) pagination.style.display = '';
  document.getElementById('editForm').style.display = 'none';
}

function insertMarkdown(before, after) {
  const textarea = document.getElementById('body');
  const start = textarea.selectionStart;
  const end = textarea.selectionEnd;
  const text = textarea.value;
  const selected = text.substring(start, end);
  const replacement = selected ? before + selected + after : before + after;
  textarea.value = text.substring(0, start) + replacement + text.substring(end);
  textarea.focus();
  const cursorPos = selected ? start + replacement.length : start + before.length;
  textarea.setSelectionRange(cursorPos, cursorPos);
}

function insertImage() {
  const url = prompt('Enter image URL:', 'https://');
  if (!url) return;
  const alt = prompt('Enter alt text:', 'image description');
  insertMarkdown('![', alt ? `${alt}](${url})` : `](${url})`);
}

function insertTable() {
  const insert = '\n| Header 1 | Header 2 | Header 3 |\n|----------|----------|----------|\n| Cell 1   | Cell 2   | Cell 3   |\n';
  insertMarkdown(insert, '');
}

function deletePost(slug) {
  fetch('/api/posts/' + slug, {
    method: 'DELETE',
    headers: { 'X-Auth-Token': authToken }
  })
  .then(res => res.json())
  .then(data => {
    if (data.confirmation_required && data.confirmation_url) {
      return fetch(data.confirmation_url, {
        method: 'POST',
        headers: { 'X-Auth-Token': authToken }
      }).then(r => r.json());
    }
    return data;
  })
  .then(data => {
    if (data.message) {
      sessionStorage.setItem('panelFlash', JSON.stringify({ message: 'Post deleted successfully', type: 'success' }));
      window.location.reload();
    } else if (data.error) {
      showNotification(data.message, 'danger');
    }
  })
  .catch(err => {
    showNotification('Failed to delete post', 'danger');
  });
}

document.addEventListener('DOMContentLoaded', () => {
  const params = new URLSearchParams(window.location.search);
  const editSlug = params.get('slug');
  if (editSlug) editPost(editSlug);
});

document.addEventListener('click', (e) => {
  const btn = e.target.closest('[data-action]');
  if (!btn) return;
  const action = btn.dataset.action;
  const slug = btn.dataset.slug;

  if (action === 'create-post') {
    e.preventDefault();
    showCreateForm();
  } else if (action === 'edit-post') {
    e.preventDefault();
    editPost(slug);
  } else if (action === 'delete-post') {
    e.preventDefault();
    showConfirmModal({
      title: 'Delete Post',
      message: 'Are you sure you want to delete this post? This action cannot be undone.',
      confirmText: 'Delete',
      confirmClass: 'is-danger',
      onConfirm: () => deletePost(slug)
    });
  } else if (action === 'cancel-edit') {
    cancelEdit();
  } else if (action === 'insert-image') {
    insertImage();
  } else if (action === 'insert-table') {
    insertTable();
  }
});

document.addEventListener('click', (e) => {
  const btn = e.target.closest('button[data-md-before]');
  if (!btn) return;
  insertMarkdown(btn.dataset.mdBefore, btn.dataset.mdAfter || '');
});

document.getElementById('postForm').addEventListener('submit', async (e) => {
  e.preventDefault();
  const slug = document.getElementById('postSlug').value;
  const formData = {
    title: document.getElementById('title').value,
    cover_image: document.getElementById('cover_image').value,
    body: document.getElementById('body').value,
    status: document.getElementById('status').value
  };

  const method = slug ? 'PUT' : 'POST';
  const url = slug ? '/api/posts/' + slug : '/api/posts';

  try {
    const res = await fetch(url, {
      method: method,
      credentials: 'same-origin',
      headers: {
        'Content-Type': 'application/json',
        'X-Auth-Token': authToken
      },
      body: JSON.stringify(formData)
    });
    const data = await res.json();
    if (data.slug || data.id) {
      const msg = slug ? 'Post updated successfully' : 'Post created successfully';
      sessionStorage.setItem('panelFlash', JSON.stringify({ message: msg, type: 'success' }));
      window.location.reload();
    } else if (data.error) {
      showNotification(data.message, 'danger');
    }
  } catch (err) {
    showNotification('Failed to save post', 'danger');
  }
});
</script>
