<section class="post-management-section">
  <% if (!isAuthenticated) { %>
  <div class="has-text-centered mb-5">
    <h1 class="title">Posts Login</h1>
    <p class="subtitle">Enter your auth token to manage posts.</p>
  </div>

  <div class="box">
    <form id="loginForm" method="POST" action="/posts/login">
      <div class="field">
        <label class="label" for="token">Auth Token</label>
        <input type="password" id="token" name="token" required placeholder="Enter your auth token">
      </div>
      <button type="submit" class="button is-primary is-fullwidth">Login</button>
    </form>
    <% if (error) { %>
    <p class="error-message mt-2"><%= error %></p>
    <% } %>
  </div>
  <% } else { %>
  <div class="has-text-centered mb-5">
    <h1 class="title">Manage Posts</h1>
    <p class="subtitle">Edit title, description, and status of your posts.</p>
  </div>

  <div id="postsList" class="post-grid">
    <% if (posts.length === 0) { %>
      <p class="has-text-grey">No posts yet. Create your first post via the API.</p>
    <% } else { %>
      <% posts.forEach(function(post) { %>
        <div class="management-card" data-slug="<%= post.slug %>">
          <h3 class="management-card-title"><%= post.title %></h3>
          <p class="management-card-excerpt"><%= post.excerpt ? post.excerpt.substring(0, 100) + '...' : '-' %></p>
          <span class="post-status is-<%= post.status %>"><%= post.status %></span>
          <div class="card-actions mt-2">
            <button class="button is-primary is-small" onclick="editPost('<%= post.slug %>')">Edit</button>
            <button class="button is-outline is-danger is-small" onclick="deletePost('<%= post.slug %>')">Delete</button>
          </div>
        </div>
    <% }); %>
    <% } %>
  </div>

  <div id="editForm" class="box mt-5" style="display: none">
    <h3 class="title is-4">Edit Post</h3>
    <form id="postEditForm" method="POST" action="/api/posts/">
      <input type="hidden" id="postSlug" name="slug" value="">
      <div class="field">
        <label class="label" for="title">Title</label>
        <input type="text" id="title" name="title" required value="">
      </div>
      <div class="field">
        <label class="label" for="description">Description</label>
        <textarea id="description" name="description"></textarea>
      </div>
      <div class="field">
        <label class="label" for="status">Status</label>
        <select id="status" name="status">
          <option value="draft">Draft</option>
          <option value="published">Published</option>
        </select>
      </div>
      <div class="field">
        <button type="button" class="button is-outline" onclick="cancelEdit()">Cancel</button>
        <button type="submit" class="button is-primary">Save</button>
      </div>
    </form>
  </div>

  <form id="logoutForm" method="POST" action="/posts/logout" class="mt-4">
    <button type="submit" class="button is-link is-outlined">Logout</button>
  </form>
  <% } %>
</section>

<% if (isAuthenticated) { %>
<script>
  const authToken = '<%= token %>';
  let currentPosts = <%- JSON.stringify(posts) %>;

  function editPost(slug) {
    const post = currentPosts.find(p => p.slug === slug);
    if (!post) return;

    document.getElementById('postsList').style.display = 'none';
    document.getElementById('editForm').style.display = 'block';
    document.getElementById('editForm').querySelector('h3').textContent = 'Edit Post';
    document.getElementById('postEditForm').action = '/api/posts/' + slug;
    document.getElementById('postSlug').value = slug;
    document.getElementById('title').value = post.title;
    document.getElementById('description').value = post.body || '';
    document.getElementById('status').value = post.status || 'draft';
  }

  function cancelEdit() {
    document.getElementById('postsList').style.display = 'grid';
    document.getElementById('editForm').style.display = 'none';
  }

  function deletePost(slug) {
    if (!confirm('Are you sure you want to delete this post?')) return;

    fetch('/api/posts/' + slug, {
      method: 'DELETE',
      headers: { 'X-Auth-Token': authToken }
    })
    .then(res => res.json())
    .then(data => {
      if (data.message) {
        window.location.reload();
      } else if (data.error) {
        alert(data.message);
      }
    })
    .catch(err => {
      alert('Failed to delete post');
    });
  }

  document.getElementById('postEditForm').addEventListener('submit', async (e) => {
    e.preventDefault();
    const slug = document.getElementById('postSlug').value;
    const formData = {
      title: document.getElementById('title').value,
      body: document.getElementById('description').value,
      status: document.getElementById('status').value
    };

    try {
      const res = await fetch('/api/posts/' + slug, {
        method: 'PUT',
        headers: {
          'Content-Type': 'application/json',
          'X-Auth-Token': authToken
        },
        body: JSON.stringify(formData)
      });
      const data = await res.json();
      if (data.slug) {
        window.location.reload();
      } else if (data.error) {
        alert(data.message);
      }
    } catch (err) {
      alert('Failed to save post');
    }
  });
</script>
<% } %>